#!/usr/bin/env bash

FIFO="$HOME/.dwmstat.fifo"
mkfifo "$FIFO"
trap "rm -f $FIFO; exit" EXIT

align() {
	printf "%-4s" "$1"
}

status() {
	# Disk usage
	DISK=$(df -h / | awk 'NR==2 {print $3 "/" $2}')

	# Date and time
	DATE=$(date +"%d.%m.%Y %H:%M")

	BATTERY=""
	EMOJI=""
	if [ "$(uname)" = 'FreeBSD' ]; then
		# Gets the 'idle' percentage and subtracts from 100
		CPU=$(iostat -c 2 | tail -n 1 | awk '{print 100 - $NF"%"}')
		# This calculates used memory by subtracting free and inactive pages from the total
		MEM=$(sysctl -n hw.physmem | awk '{print $1/1024/1024 "MB"}')
		BATTERY=$(sysctl -n hw.acpi.battery.life)%
		if [[ "$(sysctl -n hw.acpi.battery.state)" -eq 0 ]]; then
			EMOJI=$(echo "⚡")
		else
			EMOJI=$(echo "🔋")
		fi
	else
		# CPU usage
		CPU=$(top -bn1 | grep "Cpu(s)" | awk '{print 100 - $8"%"}')
		# Memory usage
		MEM=$(free -h | awk '/^Mem:/ {print $3 "/" $2}')
		# Battery
		BATTERY=$(cat /sys/class/power_supply/BAT*/capacity | awk '{s+=$1} END {print int(s/NR)"%"}')
		EMOJI=$(grep -q "Charging" /sys/class/power_supply/BAT*/status && echo "⚡" || echo "🔋")
	fi

	if [ -z "$BATTERY" ]; then
		BATTERY="N/A"
	fi

	BATTERY=$(align $BATTERY)


	BATTERY="$EMOJI $BATTERY"

	VOL="N/A"
	if command -v pactl >/dev/null; then 
		VOL=$(pactl get-sink-volume @DEFAULT_SINK@ | grep -oE '[0-9]+%' | head -1)
		MUTE=$(pactl get-sink-mute @DEFAULT_SINK@ | grep -oE 'yes|no')
		if [ "$MUTE" = "yes" ]; then
			VOL="MUTE"
		fi
	elif command -v amixer >/dev/null; then
		VOL=$(amixer sget Master | grep -oP "[0-9]*%" | head -1)
	fi

	# Output to FIFO
	echo "CPU: $(align $CPU) | MEM: $MEM | DISK: $DISK | VOL: $(align $VOL) | BAT: $BATTERY | $DATE"
}

while xsetroot -name "$(status)"; do
	sleep 10
done &

while read line < "$FIFO"; do
	xsetroot -name "$(status)"
done
